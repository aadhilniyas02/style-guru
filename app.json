{
  "expo": {
    "name": "Style Guru",
    "slug": "style-guru",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "styleguru",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.styleguru.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "backgroundColor": "#7C3AED"
      },
      "package": "com.styleguru.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Style Guru to access your camera to photograph clothing items."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Style Guru to access your photos to add clothing items."
        }
      ],
      "expo-font"
    ]
  }
}
